def _test_vision(self):
    key, url, _model, vision = self._current_client_values()

    if not url:
        self.settings_status.config(text="⚠️ Base URL 은 필수입니다.", foreground="red")
        return

    self.settings_status.config(text="🔄 Vision 연결 테스트 중...", foreground="blue")
    self.update_idletasks()

    def _test():
        try:
            test_png = self._make_test_image()
            mime, fixed, note = prepare_image_for_vision(test_png, "image/png")
            b64 = base64.b64encode(fixed).decode("ascii")

            client = OpenAI(api_key=key if key else "sk-ignored", base_url=url)
            resp = client.chat.completions.create(
                model=vision,
                messages=[
                    {
                        "role": "user",
                        "content": [
                            {"type": "text", "text": f"이 테스트 이미지를 한 문장으로 설명해주세요. 전처리: {note}"},
                            {"type": "image_url", "image_url": {"url": f"data:{mime};base64,{b64}", "detail": "high"}},
                        ],
                    }
                ],
                max_tokens=200,
                temperature=0.1,
            )
            answer = resp.choices[0].message.content.strip()[:160]
            self.after(0, lambda: self.settings_status.config(text=f"✅ Vision 연결 성공! 응답: {answer}", foreground="green"))
        except Exception as e:
            self.after(0, lambda e=e: self.settings_status.config(text=f"❌ Vision 연결 실패: {e}", foreground="red"))

    threading.Thread(target=_test, daemon=True).start()

