def detect_image_type(image_bytes: bytes, content_type: str = "") -> str: """응답 헤더와 파일 시그니처를 이용해 이미지 타입을 판별한다.""" ct = (content_type or "").split(";")[0].strip().lower()

if ct.startswith("image/"):
    return ct

head = image_bytes[:64]
stripped = image_bytes[:512].lstrip().lower()

if head.startswith(b"\x89PNG"):
    return "image/png"
if head.startswith(b"\xff\xd8\xff"):
    return "image/jpeg"
if head.startswith(b"GIF87a") or head.startswith(b"GIF89a"):
    return "image/gif"
if head.startswith(b"RIFF") and b"WEBP" in head[:16]:
    return "image/webp"
if head.startswith(b"BM"):
    return "image/bmp"
if stripped.startswith(b"<svg") or b"<svg" in stripped[:200]:
    return "image/svg+xml"
if stripped.startswith(b"<!doctype html") or stripped.startswith(b"<html"):
    return "text/html"
if stripped.startswith(b"<?xml") and b"<svg" in stripped[:500]:
    return "image/svg+xml"

return "application/octet-stream"

def _resize_for_vision(img: Image.Image, max_side: int = 1800) -> Image.Image: w, h = img.size longest = max(w, h) if longest <= max_side: return img

scale = max_side / float(longest)
new_size = (max(1, int(w * scale)), max(1, int(h * scale)))

try:
    resample = Image.Resampling.LANCZOS
except AttributeError:
    resample = Image.LANCZOS

return img.resize(new_size, resample)

def prepare_image_for_vision( image_bytes: bytes, content_type: str = "", max_side: int = 1800, ) -> Tuple[str, bytes, str]: """ Confluence에서 받은 이미지 바이트를 Vision LLM이 잘 읽는 JPEG/PNG로 표준화한다.

반환:
- mime_type: 최종 MIME 타입
- normalized_bytes: 표준화된 이미지 바이트
- note: 처리 과정 설명
"""
if not image_bytes:
    raise ValueError("빈 이미지 데이터입니다.")

original_mime = detect_image_type(image_bytes, content_type)

if original_mime == "text/html":
    raise ValueError("이미지 대신 HTML이 다운로드되었습니다. 로그인/권한/이미지 URL 문제일 수 있습니다.")

if original_mime == "image/svg+xml":
    # SVG는 서버/환경에 따라 cairosvg가 없으면 렌더링이 어렵다.
    # 여기서는 명확히 실패 처리해서 MD에 원인을 남긴다.
    raise ValueError("SVG 이미지는 현재 직접 분석 전에 PNG/JPEG 렌더링이 필요합니다.")

if not original_mime.startswith("image/"):
    raise ValueError(f"이미지로 판별되지 않는 응답입니다: {original_mime}")

try:
    img = Image.open(io.BytesIO(image_bytes))
    img.load()
except Exception as e:
    raise ValueError(f"Pillow가 이미지를 열지 못했습니다: {e}")

# GIF/WebP 애니메이션은 첫 프레임만 사용
try:
    if getattr(img, "is_animated", False):
        img.seek(0)
except Exception:
    pass

# 투명 배경 이미지 대응
if img.mode in ("RGBA", "LA", "P"):
    bg = Image.new("RGB", img.convert("RGBA").size, (255, 255, 255))
    rgba = img.convert("RGBA")
    bg.paste(rgba, mask=rgba.split()[-1])
    img = bg
elif img.mode != "RGB":
    img = img.convert("RGB")

original_size = img.size
img = _resize_for_vision(img, max_side=max_side)
resized_size = img.size

out = io.BytesIO()
img.save(out, format="JPEG", quality=92, optimize=True)
final_bytes = out.getvalue()

note = f"original={original_mime}, size={original_size[0]}x{original_size[1]}, final=image/jpeg, final_size={resized_size[0]}x{resized_size[1]}"
return "image/jpeg", final_bytes, note

