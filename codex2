def replace_img_tag_with_analysis( soup: BeautifulSoup, tag, page_session, image_url: str, alt: str, debug_dir: Optional[str] = None, ): """하나의 이미지 태그/매크로를 Vision 분석 문단으로 치환한다.""" img_desc = None err_msg = ""

if page_session and image_url:
    img_bytes, content_type, err = download_image_bytes(page_session, image_url)

    if err:
        err_msg = f"다운로드 실패: {err}"
    elif img_bytes:
        mime = detect_image_type(img_bytes, content_type)

        if mime == "text/html":
            save_debug_bytes(debug_dir, "image_html_response", img_bytes, "html")
            err_msg = "이미지 URL에서 HTML이 반환되었습니다. 로그인/권한/URL 문제 가능성이 있습니다."
        elif len(img_bytes) < 500:
            save_debug_bytes(debug_dir, "tiny_image", img_bytes, "bin")
            err_msg = f"이미지가 너무 작아 분석 제외됨 ({len(img_bytes)} bytes, {mime})"
        else:
            save_debug_bytes(debug_dir, "image_original", img_bytes, "bin")
            img_desc = llm_analyze_image(img_bytes, context=alt, content_type=content_type)
    else:
        err_msg = "빈 응답"

replacement = soup.new_tag("p")

if img_desc:
    replacement.string = f"📸 **[이미지 분석: {alt or '이미지'}]**\n\n{img_desc}"
else:
    src_short = image_url[:120] if image_url else ""
    replacement.string = f"📸 **[이미지: {alt or '이미지'}]** (분석 불가: {err_msg or '원인 미상'} / src: {src_short})"

tag.replace_with(replacement)

def html_to_markdown( html: str, page_session=None, base_url: str = "", page_id: Optional[str] = None, debug_dir: Optional[str] = None, ) -> str: """ html2text로 문서 순서를 유지한 Markdown 변환. 이미지는 다운로드 후 Vision LLM 분석 문단으로 교체한다. """ soup = BeautifulSoup(html or "", "html.parser")

# 1) 일반 img 태그 처리
for img in list(soup.find_all("img")):
    src = img.get("src", "") or img.get("data-src", "")
    alt = img.get("alt", "이미지") or img.get("title", "이미지")
    if not src:
        continue

    full_src = src if src.startswith("http") else urljoin((base_url or BASE_URL) + "/", src)
    replace_img_tag_with_analysis(
        soup=soup,
        tag=img,
        page_session=page_session,
        image_url=full_src,
        alt=alt,
        debug_dir=debug_dir,
    )

# 2) Confluence storage macro: ac:image / ri:attachment 처리
# BeautifulSoup parser에 따라 태그명이 'ac:image' 그대로 들어오는 경우가 많다.
if page_session and page_id:
    for ac_img in list(soup.find_all(lambda t: getattr(t, "name", "") in ("ac:image", "image"))):
        if ac_img.name != "ac:image":
            continue

        attachment = ac_img.find(lambda t: getattr(t, "name", "") == "ri:attachment")
        if not attachment:
            continue

        filename = attachment.get("ri:filename") or attachment.get("filename")
        if not filename:
            continue

        download_url = find_attachment_download_url(page_session, page_id, filename)
        alt = filename

        if download_url:
            replace_img_tag_with_analysis(
                soup=soup,
                tag=ac_img,
                page_session=page_session,
                image_url=download_url,
                alt=alt,
                debug_dir=debug_dir,
            )
        else:
            replacement = soup.new_tag("p")
            replacement.string = f"📸 **[이미지: {filename}]** (분석 불가: 첨부파일 다운로드 URL을 찾지 못했습니다.)"
            ac_img.replace_with(replacement)

h = html2text.HTML2Text()
h.ignore_links = False
h.ignore_images = True
h.body_width = 0
h.protect_links = True
h.wrap_links = False
h.unicode_snob = True
h.ignore_emphasis = False
h.mark_code = True

return h.handle(str(soup)).strip()

