def get_page_content(page_session, page_id: str) -> Optional[Dict]: try: resp = page_session.request.get( f"{BASE_URL}/rest/api/content/{page_id}", params={"expand": "body.storage"}, ) if resp.status != 200: return None

d = resp.json()
    return {
        "id": d.get("id"),
        "title": d.get("title", ""),
        "html": d.get("body", {}).get("storage", {}).get("value", ""),
    }
except Exception:
    return None

def get_children(page_session, parent_id: str) -> List[Dict]: pages = [] start = 0 limit = 50

while True:
    try:
        resp = page_session.request.get(
            f"{BASE_URL}/rest/api/content/search",
            params={
                "cql": f"ancestor={parent_id} and type=page",
                "start": str(start),
                "limit": str(limit),
                "expand": "version",
            },
        )
        if resp.status != 200:
            break

        data = resp.json()
        results = data.get("results", [])
        if not results:
            break

        for doc in results:
            pages.append({"id": doc["id"], "title": doc["title"]})

        if len(results) < limit:
            break

        start += limit
        if start > 2000:
            break
    except Exception:
        break

return pages

def find_attachment_download_url(page_session, page_id: str, filename: str) -> Optional[str]: """Confluence storage의 ri:attachment filename을 실제 다운로드 URL로 해석한다.""" if not filename: return None

try:
    resp = page_session.request.get(
        f"{BASE_URL}/rest/api/content/{page_id}/child/attachment",
        params={"filename": filename, "expand": "version"},
    )
    if resp.status != 200:
        return None

    data = resp.json()
    results = data.get("results", [])
    if not results:
        return None

    att = results[0]
    links = att.get("_links", {})
    download = links.get("download")
    if download:
        return urljoin(BASE_URL + "/", download)
except Exception:
    return None

return None

def download_image_bytes(page_session, image_url: str) -> Tuple[Optional[bytes], str, str]: """ 이미지 URL을 다운로드한다.

반환:
- bytes or None
- content_type
- error_message
"""
try:
    resp = page_session.request.get(image_url)
    if resp.status != 200:
        return None, "", f"HTTP {resp.status}"

    content_type = safe_get_header(resp.headers, "content-type", "")
    data = resp.body()
    return data, content_type, ""
except Exception as e:
    return None, "", str(e)

